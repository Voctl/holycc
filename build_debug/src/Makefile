	cd /home/devuan/projects/holyc/build_debug && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/holyc_core.dir/build.make src/CMakeFiles/holyc_core.dir/utils.c.o
	cd /home/devuan/projects/holyc/build_debug && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/holycc.dir/build.make src/CMakeFiles/holycc.dir/utils.c.o
.PHONY : utils.c.o

utils.i: utils.c.i
.PHONY : utils.i

# target to preprocess a source file
utils.c.i:
	cd /home/devuan/projects/holyc/build_debug && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/holyc_core.dir/build.make src/CMakeFiles/holyc_core.dir/utils.c.i
	cd /home/devuan/projects/holyc/build_debug && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/holycc.dir/build.make src/CMakeFiles/holycc.dir/utils.c.i
.PHONY : utils.c.i

utils.s: utils.c.s
.PHONY : utils.s

# target to generate assembly for a file
utils.c.s:
	cd /home/devuan/projects/holyc/build_debug && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/holyc_core.dir/build.make src/CMakeFiles/holyc_core.dir/utils.c.s
	cd /home/devuan/projects/holyc/build_debug && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/holycc.dir/build.make src/CMakeFiles/holycc.dir/utils.c.s
.PHONY : utils.c.s

